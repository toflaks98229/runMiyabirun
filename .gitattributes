# Auto detect text files and perform LF normalization
* text=auto

# --- 소스 파일 인코딩/줄바꿈 정책 ---
# 소스는 UTF-8로 저장합니다. 에디터 강제 규칙은 .editorconfig 참고.
*.cs         text diff=csharp
*.shader     text
*.hlsl       text
*.cginc      text
*.compute    text
*.json       text
*.csv        text
*.txt        text
*.md         text
*.uss        text
*.uxml       text

# Unity 직렬화 에셋 (YAML 텍스트)
*.unity      text
*.prefab     text
*.asset      text
*.mat        text
*.anim       text
*.controller text
*.meta       text
*.physicMaterial text

# 바이너리 (자동 판별에 맡기지 않음)
*.fbx        binary
*.blend      binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.psd        binary
*.tga        binary
*.tif        binary
*.exr        binary
*.hdr        binary
*.wav        binary
*.mp3        binary
*.ogg        binary
*.aif        binary
*.ttf        binary
*.otf        binary
*.dll        binary
*.so         binary
*.pdb        binary
*.unitypackage binary
